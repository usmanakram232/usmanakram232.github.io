<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <!-- no-FOUC: apply saved theme before first paint -->
  <script>try{var t=localStorage.getItem('theme')||'dark';document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Writing · M. Usman Akram</title>
  <meta name="description" content="A five-part series on building a fully declarative Linux workstation with NixOS, agentic AI tooling, and defence-in-depth security." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body:    'Inter', system-ui, sans-serif;
      --max-prose:    660px;
    }

    /* Dark mode (default) */
    [data-theme="dark"] {
      --bg:        #0f0e0c;
      --ink:       #e8e4dc;
      --ink-muted: #9e9a94;
      --ink-faint: #6b6860;
      --border:    #2a2820;
    }

    /* Light mode */
    [data-theme="light"] {
      --bg:        #f9f8f6;
      --ink:       #1a1a1a;
      --ink-muted: #4a4a4a;
      --ink-faint: #5a5652;
      --border:    #dcd8d0;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 1.05rem;
      line-height: 1.75;
      transition: background-color 0.25s ease, color 0.25s ease;
    }

    /* ── THEME TOGGLE ────────────────────── */
    .theme-toggle {
      margin-left: auto;
      flex-shrink: 0;
      background: none;
      border: 1px solid var(--ink-faint);
      border-radius: 50%;
      width: 30px;
      height: 30px;
      cursor: pointer;
      color: var(--ink-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      line-height: 1;
      transition: color 0.2s, border-color 0.2s;
    }

    .theme-toggle:hover        { color: var(--ink); border-color: var(--ink-muted); }
    .theme-toggle:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
    .theme-toggle svg           { pointer-events: none; display: block; }

    [data-theme="dark"]  .icon-sun  { display: block; }
    [data-theme="dark"]  .icon-moon { display: none; }
    [data-theme="light"] .icon-sun  { display: none; }
    [data-theme="light"] .icon-moon { display: block; }

    .site-nav {
      position: sticky;
      top: 0;
      z-index: 10;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 0.9rem clamp(1.25rem, 5vw, 2.5rem);
    }

    .site-nav a {
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .site-nav a:hover { color: var(--ink); }

    .page-wrap {
      max-width: var(--max-prose);
      margin: 0 auto;
      padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 2rem);
    }

    .page-header {
      margin-bottom: 3rem;
    }

    .page-header h1 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 400;
      letter-spacing: -0.02em;
      margin-bottom: 0.75rem;
    }

    .page-header p {
      color: var(--ink-muted);
      max-width: 520px;
    }

    /* ── SERIES BLOCK ────────────────────── */
    .series-block {
      margin-bottom: 3.5rem;
    }

    .series-label {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-faint);
      margin-bottom: 1rem;
    }

    .series-title {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--ink);
      margin-bottom: 0.5rem;
    }

    .series-desc {
      font-size: 0.9rem;
      color: var(--ink-muted);
      margin-bottom: 2rem;
      max-width: 480px;
    }

    /* ── POST LIST ───────────────────────── */
    .post-list {
      list-style: none;
      border-top: 1px solid var(--border);
    }

    .post-item {
      border-bottom: 1px solid var(--border);
    }

    .post-item a {
      display: block;
      padding: 1.25rem 0;
      text-decoration: none;
      color: inherit;
      transition: color 0.2s;
    }

    .post-item a:hover .post-title { color: var(--ink-muted); }
    .post-item a:hover .post-arrow { opacity: 1; }

    .post-inner {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }

    .post-part {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
      flex-shrink: 0;
    }

    .post-content {
      flex: 1;
    }

    .post-title {
      font-size: 1rem;
      font-weight: 300;
      color: var(--ink);
      margin-bottom: 0.2rem;
      transition: color 0.2s;
    }

    .post-desc {
      font-size: 0.85rem;
      color: var(--ink-muted);
      line-height: 1.5;
    }

    .post-arrow {
      color: var(--ink-faint);
      opacity: 0;
      transition: opacity 0.2s;
      flex-shrink: 0;
      font-size: 1rem;
    }

    /* ── FOOTER ──────────────────────────── */
    .page-footer {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .page-footer a {
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .page-footer a:hover { color: var(--ink); }

    @media (max-width: 480px) {
      .post-arrow { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { transition-duration: 0.01ms !important; }
    }
  </style>
