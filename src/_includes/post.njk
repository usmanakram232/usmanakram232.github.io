<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <!-- no-FOUC: apply saved theme before first paint -->
  <script>try{var t=localStorage.getItem('theme')||'dark';document.documentElement.setAttribute('data-theme',t)}catch(e){}</script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} · M. Usman Akram</title>
  <meta name="description" content="{{ description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --code-bg:      #1a1812;   /* always dark — code blocks never flip */
      --code-text:    #c8c4bc;
      --font-display: 'Playfair Display', Georgia, serif;
      --font-body:    'Inter', system-ui, sans-serif;
      --font-mono:    'JetBrains Mono', 'Cascadia Code', 'Fira Code', monospace;
      --max-prose:    660px;
    }

    /* Dark mode (default) */
    [data-theme="dark"] {
      --bg:              #0f0e0c;
      --ink:             #e8e4dc;
      --ink-muted:       #9e9a94;
      --ink-faint:       #6b6860;
      --border:          #2a2820;
      --border-subtle:   #222018;
      --border-table:    #1e1d1a;
      --inline-code-bg:  #1e1d1a;
      --inline-code-fg:  #c8c4bc;
      --blockquote-line: #3a3830;
    }

    /* Light mode */
    [data-theme="light"] {
      --bg:              #f9f8f6;
      --ink:             #1a1a1a;
      --ink-muted:       #4a4a4a;
      --ink-faint:       #5a5652;
      --border:          #dcd8d0;
      --border-subtle:   #d4cfc8;
      --border-table:    #e8e2d8;
      --inline-code-bg:  #ede9e0;
      --inline-code-fg:  #3a3530;
      --blockquote-line: #d4cfc8;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-body);
      font-weight: 300;
      font-size: 1.05rem;
      line-height: 1.75;
      transition: background-color 0.25s ease, color 0.25s ease;
    }

    /* ── THEME TOGGLE ────────────────────── */
    .theme-toggle {
      margin-left: auto;
      flex-shrink: 0;
      background: none;
      border: 1px solid var(--ink-faint);
      border-radius: 50%;
      width: 30px;
      height: 30px;
      cursor: pointer;
      color: var(--ink-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      line-height: 1;
      transition: color 0.2s, border-color 0.2s;
    }

    .theme-toggle:hover        { color: var(--ink); border-color: var(--ink-muted); }
    .theme-toggle:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
    .theme-toggle svg           { pointer-events: none; display: block; }

    [data-theme="dark"]  .icon-sun  { display: block; }
    [data-theme="dark"]  .icon-moon { display: none; }
    [data-theme="light"] .icon-sun  { display: none; }
    [data-theme="light"] .icon-moon { display: block; }

    /* ── NAV ─────────────────────────────── */
    .site-nav {
      position: sticky;
      top: 0;
      z-index: 10;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 0.9rem clamp(1.25rem, 5vw, 2.5rem);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .site-nav a {
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .site-nav a:hover { color: var(--ink); }

    .site-nav .sep {
      color: var(--ink-faint);
      font-size: 0.82rem;
    }

    /* ── ARTICLE ─────────────────────────── */
    .article-wrap {
      max-width: var(--max-prose);
      margin: 0 auto;
      padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 2rem);
    }

    .article-meta {
      margin-bottom: 2.5rem;
    }

    .series-tag {
      display: inline-block;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin-bottom: 1rem;
    }

    .article-meta h1 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 400;
      line-height: 1.25;
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }

    .article-date {
      font-size: 0.82rem;
      color: var(--ink-muted);
      letter-spacing: 0.04em;
    }

    /* ── PROSE ───────────────────────────── */
    .prose p {
      margin-bottom: 1.4rem;
    }

    .prose h2 {
      font-family: var(--font-display);
      font-size: clamp(1.2rem, 2.5vw, 1.5rem);
      font-weight: 400;
      margin: 3rem 0 1rem;
      color: var(--ink);
    }

    .prose h3 {
      font-size: 1rem;
      font-weight: 400;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ink-muted);
      margin: 2rem 0 0.75rem;
    }

    .prose h4 {
      font-size: 0.95rem;
      font-weight: 400;
      color: var(--ink);
      margin: 1.5rem 0 0.5rem;
    }

    .prose a {
      color: var(--ink);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--ink-faint);
      transition: text-decoration-color 0.2s;
    }

    .prose a:hover {
      text-decoration-color: var(--ink);
    }

    .prose ul, .prose ol {
      padding-left: 1.5rem;
      margin-bottom: 1.4rem;
    }

    .prose li {
      margin-bottom: 0.4rem;
    }

    .prose blockquote {
      border-left: 2px solid var(--blockquote-line);
      padding-left: 1.25rem;
      margin: 2rem 0;
      color: var(--ink-muted);
      font-style: italic;
    }

    .prose hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 3rem 0;
    }

    /* ── TABLES ──────────────────────────── */
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      font-size: 0.9rem;
    }

    .prose th {
      text-align: left;
      font-weight: 400;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-size: 0.75rem;
      color: var(--ink-muted);
      border-bottom: 1px solid var(--border-subtle);
      padding: 0.5rem 1rem 0.5rem 0;
    }

    .prose td {
      padding: 0.6rem 1rem 0.6rem 0;
      border-bottom: 1px solid var(--border-table);
      vertical-align: top;
    }

    .prose tr:last-child td { border-bottom: none; }

    /* ── INLINE CODE ─────────────────────── */
    .prose :not(pre) > code {
      font-family: var(--font-mono);
      font-size: 0.85em;
      background: var(--inline-code-bg);
      color: var(--inline-code-fg);
      padding: 0.15em 0.4em;
      border-radius: 3px;
      font-feature-settings: "liga" 0;
    }

    /* ── CODE BLOCKS (Prism) ─────────────── */
    .prose pre[class*="language-"],
    .prose pre:not([class]) {
      background: var(--code-bg);
      color: var(--code-text);
      font-family: var(--font-mono);
      font-size: 0.84rem;
      line-height: 1.65;
      font-feature-settings: "liga" 1, "calt" 1;
      padding: 1.5rem;
      border-radius: 4px;
      overflow-x: auto;
      margin: 1.75rem 0;
    }

    .prose code[class*="language-"] {
      font-family: var(--font-mono);
      font-size: inherit;
      font-feature-settings: "liga" 1, "calt" 1;
    }

    /* Warm dark token colours */
    .token.comment,
    .token.prolog,
    .token.doctype,
    .token.cdata         { color: #6b6860; font-style: italic; }
    .token.punctuation   { color: #8b8780; }
    .token.namespace     { opacity: 0.7; }
    .token.property,
    .token.tag,
    .token.boolean,
    .token.number,
    .token.constant,
    .token.symbol,
    .token.deleted       { color: #b8a070; }
    .token.selector,
    .token.attr-name,
    .token.string,
    .token.char,
    .token.builtin,
    .token.inserted      { color: #a09060; }
    .token.operator,
    .token.entity,
    .token.url           { color: #c8b880; }
    .token.atrule,
    .token.attr-value,
    .token.keyword       { color: #d4b880; }
    .token.function,
    .token.class-name    { color: #e0c890; }
    .token.regex,
    .token.important,
    .token.variable      { color: #c8c090; }
    .token.important,
    .token.bold          { font-weight: bold; }
    .token.italic        { font-style: italic; }
    .token.entity        { cursor: help; }

    /* ── SERIES NAV ──────────────────────── */
    .series-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      font-size: 0.85rem;
    }

    .series-nav a {
      color: var(--ink-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .series-nav a:hover { color: var(--ink); }

    .series-nav .next { text-align: right; }

    /* ── FOOTER ──────────────────────────── */
    .article-footer {
      margin-top: 4rem;
      padding: 2rem clamp(1.25rem, 5vw, 2.5rem);
      border-top: 1px solid var(--border);
      text-align: center;
    }

    .article-footer a {
      font-size: 0.82rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .article-footer a:hover { color: var(--ink); }

    /* ── RESPONSIVE ──────────────────────── */
    @media (max-width: 480px) {
      body { font-size: 1rem; }

      .prose pre[class*="language-"] {
        font-size: 0.78rem;
        padding: 1rem;
        border-radius: 0;
        margin: 1.5rem -1.25rem;
      }

      .prose table {
        font-size: 0.82rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      html { scroll-behavior: auto; }
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://usmanakram232.github.io/#website",
        "url": "https://usmanakram232.github.io/",
        "name": "M. Usman Akram"
      },
      {
        "@type": "Person",
        "@id": "https://usmanakram232.github.io/#person",
        "url": "https://usmanakram232.github.io/",
        "name": "M. Usman Akram",
        "sameAs": [
          "https://www.linkedin.com/in/usmanakram",
          "https://github.com/usmanakram232",
          "https://www.flickr.com/photos/usmanakram232/"
        ]
      },
      {
        "@type": "WebPage",
        "@id": "https://usmanakram232.github.io{{ page.url }}#webpage",
        "url": "https://usmanakram232.github.io{{ page.url }}",
        "isPartOf": { "@id": "https://usmanakram232.github.io/#website" },
        "name": {{ title | dump | safe }},
        "inLanguage": "en",
        "breadcrumb": { "@id": "https://usmanakram232.github.io{{ page.url }}#breadcrumb" }
      },
      {
        "@type": "BlogPosting",
        "@id": "https://usmanakram232.github.io{{ page.url }}#blogposting",
        "url": "https://usmanakram232.github.io{{ page.url }}",
        "mainEntityOfPage": { "@id": "https://usmanakram232.github.io{{ page.url }}#webpage" },
        "isPartOf": { "@id": "https://usmanakram232.github.io/blog/#blog" },
        "headline": {{ title | dump | safe }},
        "description": {{ description | dump | safe }},
        "inLanguage": "en",
        "datePublished": "{{ date | htmlDateString }}T00:00:00.000Z",
        "author": { "@id": "https://usmanakram232.github.io/#person" },
        "publisher": { "@id": "https://usmanakram232.github.io/#person" }
      },
      {
        "@type": "BreadcrumbList",
        "@id": "https://usmanakram232.github.io{{ page.url }}#breadcrumb",
        "itemListElement": [
          {
            "@type": "ListItem",
            "item": "https://usmanakram232.github.io/",
            "position": 1,
            "name": "Home"
          },
          {
            "@type": "ListItem",
            "item": "https://usmanakram232.github.io/blog/",
            "position": 2,
            "name": "Writing"
          },
          {
            "@type": "ListItem",
            "item": "https://usmanakram232.github.io{{ page.url }}",
            "position": 3,
            "name": {{ title | dump | safe }}
          }
        ]
      }
    ]
  }
  </script>
</head>
<body>

  <nav class="site-nav" aria-label="Breadcrumb">
    <a href="/">M. Usman Akram</a>
    <span class="sep" aria-hidden="true">/</span>
    <a href="/blog/">Writing</a>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch to light mode" aria-pressed="false">
      <svg class="icon-sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4.5"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      <svg class="icon-moon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </nav>

  <article>
    <div class="article-wrap">
      <header class="article-meta">
        {% if series %}
        <span class="series-tag">{{ series }}{% if part %} &middot; Part {{ part }} of {{ totalParts }}{% endif %}</span>
        {% endif %}
        <h1>{{ title }}</h1>
        <time class="article-date" datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      </header>

      <div class="prose">
        {{ content | safe }}
      </div>

      {% set sortedPosts = collections.post | sort(false, false, "data.part") %}
      {% set prevPost = null %}
      {% set nextPost = null %}
      {% for p in sortedPosts %}
        {% if p.data.part == part - 1 %}{% set prevPost = p %}{% endif %}
        {% if p.data.part == part + 1 %}{% set nextPost = p %}{% endif %}
      {% endfor %}

      <nav class="series-nav" aria-label="Series navigation">
        {% if prevPost %}
        <a href="{{ prevPost.url }}" class="prev">&#8592; {{ prevPost.data.title }}</a>
        {% else %}
        <span></span>
        {% endif %}
        {% if nextPost %}
        <a href="{{ nextPost.url }}" class="next">{{ nextPost.data.title }} &#8594;</a>
        {% endif %}
      </nav>
    </div>
  </article>

  <footer class="article-footer">
    <a href="/blog/">Back to writing</a>
  </footer>
  <script>
    (function () {
      var btn = document.getElementById('theme-toggle');
      if (!btn) return;
      function sync(theme) {
        var dark = theme === 'dark';
        btn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
        btn.setAttribute('aria-pressed', String(!dark));
      }
      sync(document.documentElement.getAttribute('data-theme') || 'dark');
      btn.addEventListener('click', function () {
        var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (e) {}
        sync(next);
      });
    })();
  </script>

</body>
</html>
